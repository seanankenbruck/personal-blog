# Development Environment Configuration
# Copy this file to .env and update with actual values

# Database Configuration (Individual variables for development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=blog
DB_SSLMODE=disable

# Alternative Database URL format (if preferred)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/blog?sslmode=disable

# JWT Configuration
JWT_SECRET=dev-jwt-secret-key-change-in-production

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_SENDER=your-email@gmail.com
APP_HOST=http://localhost:8080

# Application Configuration
GIN_MODE=debug
PORT=8080
LOG_LEVEL=debug

# Security
CORS_ORIGIN=http://localhost:8080
SESSION_SECRET=dev-session-secret-key

# Monitoring
ENABLE_METRICS=false
METRICS_PORT=9090

# Cache Configuration (Optional)
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# File Upload
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_PATH=./uploads

# Development-specific settings
DEBUG=true
ENABLE_LOGGING=true