# Staging Environment Configuration
# Copy this file to .env and update with actual values

# Database Configuration (Individual variables for staging)
DB_HOST=your-staging-db-host
DB_PORT=5432
DB_USER=blog_user
DB_PASSWORD=your-staging-password
DB_NAME=blog_db
DB_SSLMODE=require

# Alternative Database URL format (if preferred)
# DATABASE_URL=postgres://blog_user:your-staging-password@your-staging-db-host:5432/blog_db?sslmode=require

# JWT Configuration
JWT_SECRET=staging-jwt-secret-key-change-in-production

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_SENDER=your-email@gmail.com
APP_HOST=https://staging.your-domain.com

# Application Configuration
GIN_MODE=release
PORT=8080
LOG_LEVEL=info

# Security
CORS_ORIGIN=https://staging.your-domain.com
SESSION_SECRET=staging-session-secret-key

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Cache Configuration (Optional)
REDIS_URL=redis://your-staging-redis-host:6379
CACHE_TTL=3600

# File Upload
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_PATH=/app/uploads

# Staging-specific settings
DEBUG=false
ENABLE_LOGGING=true